MONGODB_URI=mongodb://localhost:27017/fastapp
JWT_SECRET=change_this_secret
PORT=4000

# Public URL of your backend (used in MPESA callback URLs, e.g. ngrok URL in dev)
APP_PUBLIC_URL=https://your-public-backend-url

# MPESA sandbox / production credentials
# Leave these empty to run in simulation mode (no real money moves).
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=

# Optional metadata for statements and transaction descriptions
MPESA_ACCOUNT_REFERENCE=FastApp
MPESA_TRANSACTION_DESC=Wallet Deposit

# Base URL for Safaricom APIs (sandbox default; change for production)
MPESA_BASE_URL=https://sandbox.safaricom.co.ke

# This must exactly match the STK callback URL you register in Daraja.
# e.g. https://your-public-backend-url/api/mpesa/stk-callback
MPESA_STK_CALLBACK_URL=

# Used for B2C / transaction status APIs (mainly withdrawals / verification)
MPESA_INITIATOR=
MPESA_SECURITY_CREDENTIAL=
MPESA_RESULT_URL=
MPESA_TIMEOUT_URL=
